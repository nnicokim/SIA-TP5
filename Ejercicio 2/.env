# =====================================================================
#  CONFIGURACION DEL EXPERIMENTO VAE (Kanjis)  -  Ejercicio 2
# =====================================================================

# --- Espacio latente ---
VAE_LATENT_DIMS=[2]

# --- Arquitecturas (capas ocultas del encoder; el decoder es su espejo) ---
VAE_ARCH_CONFIGS=[[16, 8], [32, 16], [64, 32], [32, 16, 8], [64, 32, 16]]

# --- Learning rates a barrer ---
VAE_LR_CONFIGS=[0.1, 0.01, 0.001, 0.0005]

# --- Pesos de la divergencia KL (beta) ---
# Estudio del posterior collapse: beta chico -> KL activa (buena reconstruccion),
# beta grande -> KL colapsa a 0 (latente degenerado). Rango ampliado hacia abajo
# respecto del .env de recuperatorio para evidenciar el gradiente de colapso.
VAE_BETA_CONFIGS=[0.001, 0.01, 0.1, 1.0]

# --- Baselines para los barridos de UN factor por vez ---
# (al barrer arquitectura se fija LR_BASE y BETA_BASE; etc.)
VAE_LR_BASE=0.001
VAE_BETA_BASE=0.01

# --- Early stopping (reemplaza el "setear N epocas fijas") ---
# Se entrena hasta convergencia: si la loss total no mejora mas de ES_MIN_DELTA
# durante ES_PATIENCE epocas seguidas, se corta. ES_MAX_EPOCHS es el tope de seguridad.
ES_MAX_EPOCHS=5000
ES_PATIENCE=200
ES_MIN_DELTA=0.0001

# --- Generales ---
BATCH_SIZE=32
USE_CUDA=false
SEED=42
