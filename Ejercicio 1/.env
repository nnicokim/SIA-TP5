# ==============================================================================
# CONFIGURACIÓN DE HIPERPARÁMETROS EXPANDIDA - S  SIA-TP5
# ==============================================================================

# LATENT_DIMS: Dimensión del cuello de botella (Bottleneck).
# - Controla el nivel de compresión del espacio.
# - Evaluamos 2D (compresión crítica y visualizable), junto con 3D y 4D para medir 
#   cuánta información morfológica recuperamos al relajar la restricción geométrica.
LATENT_DIMS="[2]"

# ARCH_CONFIGS: Filtros jerárquicos de las capas ocultas del Encoder.
# - [16, 8], [32, 16] y [64, 32]: Estructuras de 2 capas para reducciones directas.
# - [32, 16, 8] y [64, 32, 16]: Configuraciones de 3 capas añadidas específicamente para 3D y 4D.
#   Permiten que la pérdida tipográfica decante suavemente antes de llegar al cuello de botella.
ARCH_CONFIGS="[[16, 8], [32, 16], [64, 32], [32, 16, 8], [64, 32, 16]]"

# LR_CONFIGS: Tasas de aprendizaje (Learning Rate) para el algoritmo Adam.
# - 0.1: Prueba extrema. Suele causar divergencia o hacer que el MSE oscile sin converger.
# - 0.01 y 0.001: Rangos estándar de la industria para optimizaciones estables.
# - 0.0005: Ajuste micro-métrico. Lento pero ideal para exprimir el error mínimo en épocas tardías.
LR_CONFIGS="[0.1, 0.01, 0.001, 0.0005]"

# BATCH_SIZE: Tamaño del lote de entrenamiento.
# - Fijado en 32 porque el archivo font.h contiene exactamente 32 filas (caracteres).
#   Al coincidir, ejecutamos Batch Gradient Descent puro por época, asegurando gradientes ultra-estables.
BATCH_SIZE=32

# EPOCHS_CONFIGS: Cantidad de iteraciones completas sobre el set de datos.
# - Evaluamos desde 500 (convergencia preliminar) hasta 2000 (techo asintótico).
#   Permite verificar en qué punto el modelo empieza a estancarse o si existe riesgo de sobreajuste.
EPOCHS_CONFIGS="[500, 1000, 1500, 2000]"